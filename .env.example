# ─── LLM ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ─── SEARCH ──────────────────────────────────────────────────────────
# Get a free key at https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ─── DATABASE ────────────────────────────────────────────────────────
# Long-term memory (Postgres). For local dev: postgresql://user:pass@localhost:5432/moroccan_kitchen
# If you don't have Postgres, set USE_SQLITE_FALLBACK=true and SQLite is used instead.
DATABASE_URL=postgresql://user:password@localhost:5432/db_name
USE_SQLITE_FALLBACK=false

# ─── APP ─────────────────────────────────────────────────────────────
# Debug mode prints full agent traces in the terminal
DEBUG=false
